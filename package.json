{
  "name": "morkro.de",
  "version": "26.02.0.M1",
  "description": "Website of Moritz Kröger",
  "homepage": "https://moritz.berlin",
  "author": "Moritz Kröger <write@morkro.de>",
  "type": "module",
  "imports": {
    "#config": "./ssg/config.ts",
    "#parser/*": "./ssg/parser/*",
    "#utils/*": "./ssg/utils/*",
    "#root/*": "./ssg/*"
  },
  "scripts": {
    "clean:site": "rimraf _site",
    "lint:js": "biome lint --error-on-warnings ./src/scripts/",
    "lint:css": "biome lint --error-on-warnings src/css/**/*.css",
    "lint": "npm run lint:js && npm run lint:css",
    "setup": "npm run clean:site && npm run lint",
    "build:css": "postcss src/css/*.css --no-map --dir _site/css",
    "watch:css": "postcss src/css/*.css --no-map --dir _site/css --watch",
    "build": "cross-env NODE_ENV=production npm run setup && npx @11ty/eleventy",
    "start": "cross-env NODE_ENV=development npm run setup && npx @11ty/eleventy --serve --quiet",
    "build:ssg": "node --experimental-transform-types ssg/index.ts",
    "start:ssg": "node --experimental-transform-types --watch --env-file=.env ssg/index.ts --serve",
    "test": "node --experimental-transform-types --test",
    "parse:liquid": "DEBUG=true node --experimental-transform-types --watch-path=ssg/parser --watch-preserve-output ssg/parser/index.ts --parse=liquid",
    "prepare": "husky"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-bundle": "^3.0.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@biomejs/biome": "^1.9.4",
    "@types/html-minifier": "^4.0.5",
    "@types/postcss-import": "^14.0.3",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "rimraf": "^6.0.1",
    "snyk": "^1.1295.4"
  },
  "dependencies": {
    "html-minifier": "^4.0.0"
  },
  "snyk": true
}