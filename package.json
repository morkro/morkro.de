{
  "name": "morkro.de",
  "version": "26.07.111.M2",
  "description": "Website of Moritz Kröger",
  "homepage": "https://moritz.berlin",
  "author": "Moritz Kröger <write@morkro.de>",
  "type": "module",
  "imports": {
    "#commands/*": "./core/commands/*",
    "#config.user": "./core/config.user.ts",
    "#config": "./core/config.core.ts",
    "#core/*": "./core/*",
    "#data/*": "./core/data/*",
    "#emitter/*": "./core/emitter/*",
    "#engines/*": "./core/engines/*",
    "#parser/*": "./core/parser/*",
    "#server/*": "./core/server/*",
    "#transforms/*": "./core/transforms/*",
    "#utils/*": "./core/utils/*"
  },
  "scripts": {
    "clean:build": "node scripts/clean-artifacts.ts",
    "lint:js": "biome lint --error-on-warnings ./src/scripts/ ./core/",
    "lint:css": "biome lint --error-on-warnings src/css/**/*.css",
    "lint": "npm run lint:js && npm run lint:css",
    "setup": "npm run clean:build && npm run lint",
    "build": "NODE_ENV=production node core/index.ts",
    "start": "node --watch --env-file=.env core/index.ts --serve",
    "test": "node --test 'test/**/*.test.ts'",
    "test:liquid": "DEBUG=true node test/fixtures/liquid/run.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "snyk": "^1.1295.4"
  },
  "snyk": true
}