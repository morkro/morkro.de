<footer id="page-footer">
	<svg
		class="section-border black"
		viewBox="0 0 1440 45"
		aria-hidden="true"
		focusable="false"
	>
		<use xlink:href="#border"></use>
	</svg>
	<div class="footer-inner container-large grid">
		<div class="footer-info col-4">
			<p>
				I am Moritz Kröger, Director of Engineering and Open
				Source contributor who lives in Berlin. I usually go with
				<a
					href="https://www.google.de/search?q=morkro"
					target="_blank"
					rel="noopener"
					>morkro</a
				>
				(almost) everywhere, but here are a few handy links anyway:
			</p>

			<ul class="footer-socialmedia">
				<li>
					<a href="mailto:{{ site_email }}">
						<svg aria-hidden="true" focusable="false">
							<use xlink:href="#mail"></use>
						</svg>
						<span class="sr-only">E-Mail</span>
					</a>
				</li>
				<li>
					<a
						href="{{ socialnetworks_linkedin_url }}"
						target="_blank"
						rel="noopener noreferrer"
						title="LinkedIn"
					>
						<svg aria-hidden="true" focusable="false">
							<use xlink:href="#linkedin"></use>
						</svg>
						<span class="sr-only">LinkedIn</span>
					</a>
				</li>
				<li>
					<a
					href="{{ socialnetworks_github_url }}"
					target="_blank"
					rel="noopener noreferrer"
					title="Github"
					>
						<svg aria-hidden="true" focusable="false">
							<use xlink:href="#github"></use>
						</svg>
						<span class="sr-only">GitHub</span>
					</a>
				</li>
				<li>
					<a
						href="{{ socialnetworks_stackoverflow_url }}"
						target="_blank"
						rel="noopener noreferrer"
						title="StackOverflow"
					>
						<svg aria-hidden="true" focusable="false">
							<use xlink:href="#stackoverflow"></use>
						</svg>
						<span class="sr-only">StackOverflow</span>
					</a>
				</li>
				<li>
					<a
						href="{{ socialnetworks_instagram_url }}"
						target="_blank"
						rel="noopener noreferrer"
						title="Instagram"
					>
						<svg aria-hidden="true" focusable="false">
							<use xlink:href="#instagram"></use>
						</svg>
						<span class="sr-only">Instagram</span>
					</a>
				</li>
			</ul>

			<div class="footer-content">
				<p>
					This website <span data-tooltip data-tooltip-message="$year.$month.$commits.$type=M1|M2|P0" tabindex="0">(v{{ pkg_version }}<svg aria-hidden="true" focusable="false"><use xlink:href="#question"></use></svg>)</span> is made using (almost) no dependencies and all content is
					<a
						href="{{ socialnetworks_github_url }}/morkro.de"
						target="_blank"
						rel="noopener noreferrer"
						class="anim-underline"
						>open source</a
					>.
					<br />
					© <span class="footer-year">{% currentYear %}</span> Moritz Kröger
				</p>
			</div>
		</div>

		<div class="footer-menu col-2">
			{% render "menu", location: 'footer', title: title %}
			<a href="#top" class="footer-gotop" data-scrollto="#">
				<span class="sr-only">Back to top</span>
				<svg aria-hidden="true" focusable="false">
					<use xlink:href="#arrow-top"></use>
				</svg>
				<svg class="footer-gotop-blob" aria-hidden="true" focusable="false">
					<use xlink:href="#blob"></use>
				</svg>
			</a>
		</div>
	</div>
</footer>
