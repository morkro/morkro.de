{%- if title -%}
  {% assign title = title | append: ' | ' | append: site.author %}
{%- else -%}
  {% assign title = site.author %}
{%- endif -%}
{%- if meta.robots -%}
  {% assign robots = meta.robots %}
{%- else -%}
  {% assign robots = 'index,follow' %}
{%- endif %}
{%- if meta.description -%}
  {% assign description = meta.description %}
{%- else -%}
  {% assign description = site.description %}
{%- endif %}
<head>
  <title>
    {{- title -}}
  </title>
  <meta charset="utf-8" />
  <meta name="robots" content="{{ robots }}" />
  <meta name="revisit-after" content="1 days" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content="morkro" />
  <meta name="theme-color" content="#3652CF" />
  <meta name="color-scheme" content="light dark" />

    <!-- Meta data -->
  <meta name="author" content="{{ site.author }}" />
  {%- if keywords -%}
    <meta name="keywords" content="{{ keywords | join: ',' }}" />
  {%- endif -%}
  <meta name="description" content="{{ description }}" />
  <link rel="canonical" href="{{ page.url }}" />
  <link rel="shortcut icon" href="/assets/favicon.ico" />
  <link rel="author" href="/humans.txt" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title="{{- title }} RSS"
    href="/feed.xml" />

    <!-- Open Graph data -->
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:image" content="{{ site.url }}/assets/img/moritz-mountains.webp" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ page.url }}" />

    <!-- Stylesheets -->
  <link
    rel="stylesheet"
    type="text/css"
    href="/css/main.css?v={{ pkg.version }}-{{ site.timestamp }}" />
  {%- if pageClass -%}
    <link
      rel="stylesheet"
      type="text/css"
      href="/css/{{ pageClass }}.css?v={{ pkg.version }}-{{ site.timestamp }}" />
  {%- endif -%}
</head>